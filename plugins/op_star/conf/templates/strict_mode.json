{
    "name": "严格安全模式",
    "desc": "所有防护模块全部开启 + 加强版 CC 防护 + HTTP 请求方法限制，适合对安全要求极高的生产环境和金融/政务类站点。",
    "rules": {
        "base": {
            "allow": "on",
            "ipMod": "on",
            "host_methodMod": "on",
            "uriMod": "on",
            "useragentMod": "on",
            "cookieMod": "on",
            "argsMod": "on",
            "postMod": "on",
            "networkMod": "on"
        },
        "args_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - SELECT查询探测",
                "args_data": [
                    "\\bselect\\b.*\\bfrom\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - UNION联合注入",
                "args_data": [
                    "\\bunion\\b.*\\bselect\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - 布尔盲注",
                "args_data": [
                    "\\b(and|or)\\b\\s+\\d+\\s*=\\s*\\d+",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - 写操作关键字",
                "args_data": [
                    "\\b(insert|update|delete|drop|truncate|alter|create)\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - 高级函数探测",
                "args_data": [
                    "\\bconcat\\b|\\bchar\\b\\s*\\(|\\bsubstring\\b|\\bbenchmark\\b|\\bsleep\\b\\s*\\(",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "XSS攻击 - script标签注入",
                "args_data": [
                    "<script[^>]*>",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "XSS攻击 - 事件处理器注入",
                "args_data": [
                    "\\bon\\w+\\s*=",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "XSS攻击 - 协议注入（含vbscript/data）",
                "args_data": [
                    "javascript\\s*:|vbscript\\s*:|data\\s*:",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "远程命令/代码执行探测",
                "args_data": [
                    "\\bexec\\b.*\\bmaster\\b|\\bresponse\\.write\\b|\\beval\\s*\\(",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - 时间盲注/排序探测",
                "args_data": [
                    "\\bwaitfor\\b.*\\bdelay\\b|\\border\\s+by\\s+\\d+",
                    "ji"
                ]
            }
        ],
        "uri_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "目录遍历攻击 - 路径穿越",
                "uri": [
                    "\\.\\./",
                    "j"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "敏感文件探测 - 备份/压缩/配置",
                "uri": [
                    "\\.(bak|swp|old|sql|log|conf|ini|env|git|svn|DS_Store|tar\\.gz|zip|rar)$",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "WordPress 攻击探测",
                "uri": [
                    "/wp-admin/|/wp-login\\.php|/xmlrpc\\.php|/wp-cron\\.php",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "数据库管理工具探测",
                "uri": [
                    "/phpmyadmin|/pma|/myadmin|/mysql|/adminer",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "隐藏文件/版本控制目录探测",
                "uri": [
                    "/\\.well-known/|/\\.env|/\\.git/|/\\.svn/|/\\.htaccess|/\\.htpasswd",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "WebShell 木马路径探测",
                "uri": [
                    "/shell\\.php|/cmd\\.php|/hack\\.php|/c99\\.php|/r57\\.php",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "中间件管理后台探测",
                "uri": [
                    "/cgi-bin/|/manager/html|/solr/|/actuator|/druid",
                    "ji"
                ]
            }
        ],
        "useragent_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "恶意扫描器 - 安全工具特征",
                "useragent": [
                    "sqlmap|nmap|nikto|dirbuster|w3af|acunetix|nessus|appscan",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "恶意扫描器 - 暴力/渗透工具",
                "useragent": [
                    "masscan|zgrab|nuclei|gobuster|ffuf|wfuzz|hydra|burp|zap",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "自动化爬虫 - 编程语言/工具默认UA",
                "useragent": [
                    "scrapy|mechanize|python-requests/|go-http-client|java/|perl|wget|curl/",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "空User-Agent拦截",
                "useragent": [
                    "^$",
                    "j"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "通用爬虫拦截 (可能误杀搜索引擎爬虫)",
                "useragent": [
                    "bot|spider|crawl|slurp",
                    "ji"
                ]
            }
        ],
        "cookie_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "Cookie SQL注入攻击",
                "cookie": [
                    "\\bselect\\b.*\\bfrom\\b|\\bunion\\b.*\\bselect\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "Cookie XSS注入攻击",
                "cookie": [
                    "<script|javascript\\s*:|\\bon\\w+\\s*=",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "Cookie 路径穿越攻击",
                "cookie": [
                    "\\.\\.[\\/\\\\]",
                    "ji"
                ]
            }
        ],
        "post_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "POST SQL注入攻击",
                "posts_data": [
                    "\\bselect\\b.*\\bfrom\\b|\\bunion\\b.*\\bselect\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "POST XSS注入攻击",
                "posts_data": [
                    "<script[^>]*>|\\bon\\w+\\s*=|javascript\\s*:",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "POST 远程代码执行",
                "posts_data": [
                    "\\bexec\\s*\\(|\\beval\\s*\\(|\\bsystem\\s*\\(|\\bpassthru\\s*\\(|\\bpopen\\s*\\(",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "POST 路径穿越攻击",
                "posts_data": [
                    "\\.\\.[\\/\\\\]",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "POST 命令注入攻击",
                "posts_data": [
                    "\\bcmd\\b|\\bpowershell\\b|/bin/bash|/bin/sh",
                    "ji"
                ]
            }
        ],
        "host_method_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "限制非标准HTTP方法 (仅允许GET/POST/HEAD)",
                "host_method": [
                    "PUT|DELETE|PATCH|OPTIONS|TRACE|CONNECT"
                ]
            }
        ],
        "network_Mod": [
            {
                "state": "on",
                "action": "deny",
                "network": {
                    "maxReqs": 60,
                    "pTime": 60,
                    "blackTime": 1800
                },
                "name": "严格CC防护 - 60秒60次封禁30分钟"
            },
            {
                "state": "on",
                "action": "deny",
                "network": {
                    "maxReqs": 15,
                    "pTime": 5,
                    "blackTime": 600
                },
                "name": "突发洪水防护 - 5秒15次封禁10分钟"
            }
        ]
    }
}