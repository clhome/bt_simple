{
    "name": "基础安全加固",
    "desc": "覆盖 SQL注入/XSS/目录遍历/恶意爬虫/Cookie注入/POST攻击等常见攻击面，适合所有站点一键开启基础防护。",
    "rules": {
        "base": {
            "allow": "on",
            "ip_Mod": "on",
            "host_method_Mod": "off",
            "uri_Mod": "on",
            "useragent_Mod": "on",
            "cookie_Mod": "on",
            "args_Mod": {
                "state": "on",
                "HPP_state": "on"
            },
            "post_Mod": {
                "state": "on",
                "HPP_state": "on"
            },
            "network_Mod": "off"
        },
        "args_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - SELECT查询探测",
                "args_data": [
                    "\\bselect\\b.*\\bfrom\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - UNION联合注入",
                "args_data": [
                    "\\bunion\\b.*\\bselect\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - 布尔盲注",
                "args_data": [
                    "\\b(and|or)\\b\\s+\\d+\\s*=\\s*\\d+",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "SQL注入 - 写操作关键字",
                "args_data": [
                    "\\b(insert|update|delete|drop|truncate|alter|create)\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "XSS攻击 - script标签注入",
                "args_data": [
                    "<script[^>]*>",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "XSS攻击 - 事件处理器注入",
                "args_data": [
                    "\\bon\\w+\\s*=",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "XSS攻击 - javascript伪协议",
                "args_data": [
                    "javascript\\s*:",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "通用攻击 - 远程命令执行探测",
                "args_data": [
                    "\\bexec\\b.*\\bmaster\\b|\\bresponse\\.write\\b",
                    "ji"
                ]
            }
        ],
        "uri_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "目录遍历攻击 - 路径穿越",
                "uri": [
                    "\\.\\./",
                    "j"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "敏感文件探测 - 备份/配置文件",
                "uri": [
                    "\\.(bak|swp|old|sql|log|conf|ini|env|git|svn|DS_Store)$",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "WordPress 攻击探测 (非WP站点适用)",
                "uri": [
                    "/wp-admin/|/wp-login\\.php|/xmlrpc\\.php",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "数据库管理工具探测",
                "uri": [
                    "/phpmyadmin|/pma|/myadmin|/mysql",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "隐藏文件/目录探测",
                "uri": [
                    "/\\.well-known/|/\\.env|/\\.git/",
                    "ji"
                ]
            }
        ],
        "useragent_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "恶意扫描器 - 安全工具特征",
                "useragent": [
                    "sqlmap|nmap|nikto|dirbuster|w3af|acunetix|nessus|appscan",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "恶意扫描器 - 暴力探测工具",
                "useragent": [
                    "masscan|zgrab|nuclei|gobuster|ffuf|wfuzz|hydra",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "自动化爬虫 - 编程语言默认UA",
                "useragent": [
                    "scrapy|mechanize|python-requests/|go-http-client|java/",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "空User-Agent拦截",
                "useragent": [
                    "^$",
                    "j"
                ]
            }
        ],
        "cookie_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "Cookie SQL注入攻击",
                "cookie": [
                    "\\bselect\\b.*\\bfrom\\b|\\bunion\\b.*\\bselect\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "Cookie XSS注入攻击",
                "cookie": [
                    "<script|javascript\\s*:|\\bon\\w+\\s*=",
                    "ji"
                ]
            }
        ],
        "post_Mod": [
            {
                "state": "on",
                "action": "deny",
                "name": "POST SQL注入攻击",
                "posts_data": [
                    "\\bselect\\b.*\\bfrom\\b|\\bunion\\b.*\\bselect\\b",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "POST XSS注入攻击",
                "posts_data": [
                    "<script[^>]*>|\\bon\\w+\\s*=|javascript\\s*:",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "POST 远程代码执行",
                "posts_data": [
                    "\\bexec\\s*\\(|\\beval\\s*\\(|\\bsystem\\s*\\(|\\bpassthru\\s*\\(",
                    "ji"
                ]
            },
            {
                "state": "on",
                "action": "deny",
                "name": "POST 路径穿越攻击",
                "posts_data": [
                    "\\.\\.[\\/\\\\]",
                    "ji"
                ]
            }
        ]
    }
}